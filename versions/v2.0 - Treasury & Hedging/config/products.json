  "margin_calc": {
    "_note": "Two interchangeable margin formulas from Tables & Data E19:L32",
    "simple": {
      "description": "Fixed price (KRs) — no VAT",
      "forward":  "price = spot × (1 + margin/100)",
      "backward_margin": "margin = (price/spot - 1) × 100",
      "backward_spot":   "spot = price / (1 + margin/100)"
    },
    "vat_inclusive": {
      "description": "Minted bars / silver — 15% VAT inclusive",
      "vat_rate": 0.15,
      "forward":  "price_vat_incl = spot × oz_per_unit × (1 + margin/100) × 1.15",
      "backward_margin": "margin = ((price_vat_incl/1.15) / (spot × oz_per_unit) - 1) × 100",
      "backward_spot":   "spot = (price_vat_incl/1.15) / (oz_per_unit × (1 + margin/100))"
    }
  }
